<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="1200" height="630" fill="#0a0a0a"/>
  <!-- Grid lines -->
  <defs>
    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="1200" height="630" fill="url(#grid)"/>
  <!-- Amber glow -->
  <circle cx="200" cy="315" r="300" fill="rgba(245,158,11,0.05)"/>
  <!-- Icon -->
  <text x="90" y="300" font-size="80" fill="#f59e0b">⚖</text>
  <!-- Title -->
  <text x="90" y="360" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="72" font-weight="700" fill="white" letter-spacing="-2">tribunal</text>
  <!-- Tagline -->
  <text x="90" y="420" font-family="-apple-system, BlinkMacSystemFont, sans-serif" font-size="28" fill="rgba(255,255,255,0.5)">Enterprise Claude Code Enhancement</text>
  <!-- Border accent -->
  <rect x="90" y="460" width="200" height="3" fill="#f59e0b"/>
  <!-- URL -->
  <text x="90" y="510" font-family="monospace" font-size="20" fill="rgba(255,255,255,0.25)">tribunal.dev</text>
</svg>
