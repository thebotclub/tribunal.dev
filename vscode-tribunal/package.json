{
  "name": "tribunal-vscode",
  "displayName": "Tribunal — Claude Code Governance",
  "description": "VS Code extension for Tribunal: real-time rule status, audit viewer, cost tracking, and team dashboard for Claude Code governance.",
  "version": "0.1.0",
  "publisher": "thebotclub",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "tribunal",
    "claude-code",
    "governance",
    "ai-safety",
    "audit"
  ],
  "activationEvents": [
    "workspaceContains:.tribunal/rules.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tribunal",
          "title": "Tribunal",
          "icon": "media/tribunal-icon.svg"
        }
      ]
    },
    "views": {
      "tribunal": [
        {
          "id": "tribunal.rules",
          "name": "Rules"
        },
        {
          "id": "tribunal.audit",
          "name": "Audit Log"
        },
        {
          "id": "tribunal.agents",
          "name": "Agents"
        },
        {
          "id": "tribunal.cost",
          "name": "Cost"
        }
      ]
    },
    "commands": [
      {
        "command": "tribunal.refresh",
        "title": "Tribunal: Refresh Views",
        "icon": "$(refresh)"
      },
      {
        "command": "tribunal.doctor",
        "title": "Tribunal: Run Doctor"
      },
      {
        "command": "tribunal.initProject",
        "title": "Tribunal: Initialize Project"
      },
      {
        "command": "tribunal.rotateAudit",
        "title": "Tribunal: Rotate Audit Log"
      },
      {
        "command": "tribunal.validateConfig",
        "title": "Tribunal: Validate Config"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tribunal.refresh",
          "when": "view =~ /tribunal\\./",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Tribunal",
      "properties": {
        "tribunal.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh views when .tribunal files change."
        },
        "tribunal.dashboardUrl": {
          "type": "string",
          "default": "",
          "description": "URL of the team dashboard API endpoint."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  }
}
